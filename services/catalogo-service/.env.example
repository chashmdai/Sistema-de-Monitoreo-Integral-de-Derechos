# ============================================================================
# SMID 6.7 — Catálogo de Derechos · variables de entorno (PLANTILLA)
# ----------------------------------------------------------------------------
# Copiar a .env y completar con valores reales. NUNCA versionar el .env real.
# ============================================================================

# --- Base de datos (MySQL 8) ---
# connectionTimeZone=UTC alinea el manejo de tiempo con el servicio (Núcleo 2.10).
DB_URL=jdbc:mysql://localhost:3306/db_catalogo?useSSL=false&allowPublicKeyRetrieval=true&connectionTimeZone=UTC&characterEncoding=UTF-8
DB_USER=catalogo
DB_PASSWORD=cambiar_esta_clave

# --- JWT (contrato 2.4; validación independiente, DT-3) ---
# El secreto se usa como bytes UTF-8 para HS256 y debe tener AL MENOS 32 caracteres.
# Debe coincidir, junto con su kid, con el configurado en el servicio de autenticación.
JWT_KID=smid-2026-06
JWT_SECRET=clave_compartida_de_al_menos_32_caracteres_____
JWT_ISSUER=smid-auth
JWT_AUDIENCE=smid-servicios

# --- Rotación de claves (OPCIONAL): completar solo durante una rotación ---
JWT_KID_PREVIO=
JWT_SECRET_PREVIO=

# --- Autorización ---
# Roles que confieren Administración (escritura), separados por comas.
SMID_SEGURIDAD_ROLES_ADMINISTRACION=ADMIN_NACIONAL,ADMIN_CATALOGO,ADMINISTRADOR

# --- Perfil de ejecución ---
# 'local' habilita trazas SQL y logs de depuración. Dejar vacío en producción.
SPRING_PROFILES_ACTIVE=local
