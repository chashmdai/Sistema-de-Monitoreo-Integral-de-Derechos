# =====================================================================================
#  casos-service (SMID 6.4) — Variables de entorno (ejemplo)
#  Copiar a .env y completar. NO versionar el .env real con secretos.
# =====================================================================================

# ---- Servidor ----
SERVER_PORT=8090

# ---- Base de datos (MySQL 8) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_casos
DB_USER=smid
DB_PASSWORD=cambiar-en-entorno
DB_POOL_MAX=10

# ---- RabbitMQ ----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ---- JWT (HS256 con kid) ----
JWT_ISSUER=smid-auth
JWT_AUDIENCE=smid-servicios
JWT_KID=smid-2026-06
JWT_SECRET=cambiar-en-entorno-secreto-hs256-minimo-32-bytes
# Ventana de rotación (opcional)
JWT_KID_PREVIO=
JWT_SECRET_PREVIO=

# ---- Autorización ----
ROLES_COORDINACION=COORDINADOR,COORDINACION,ADMIN_SEDE,ADMIN_NACIONAL

# ---- Numeración de expediente ----
EXPEDIENTE_INICIO_OFICIAL=2027-01-01

# ---- Sedes ----
CODIGO_SEDE_DEFECTO=RM

# ---- Eventos ----
# consumo: rabbitmq (habilita listener) | none (desactiva)
EVENTOS_CONSUMO=rabbitmq
# transporte: rabbitmq | log
EVENTOS_TRANSPORTE=rabbitmq

# ---- Enriquecimiento on-demand (opcional) ----
ENRIQUECIMIENTO_ACTIVO=false
REQUERIMIENTOS_URL=http://localhost:8089

# ---- Logging ----
LOG_LEVEL_CASOS=INFO
