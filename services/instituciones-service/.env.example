# =============================================================================
# instituciones-service (SMID 6.10) — Variables de entorno (ejemplo)
# Copiar a .env y completar con valores reales. NUNCA versionar el .env real.
# =============================================================================

# --- Base de datos MySQL 8 ---
DB_URL=jdbc:mysql://localhost:3306/db_instituciones?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&tinyInt1isBit=true&connectionTimeZone=UTC
DB_USER=smid_instituciones
DB_PASSWORD=cambiar_esta_clave
DB_POOL_MAX=10

# --- Servidor ---
SERVER_PORT=8093

# --- JWT (HS256). El secreto se comparte BYTE A BYTE con el Gateway/Identidad ---
JWT_SECRET=clave-hs256-de-al-menos-32-bytes-cambiar
JWT_KID_ACTIVO=smid-2026-06
# Rotación opcional (dejar vacíos si no se usan):
JWT_KID_PREVIO=
JWT_SECRET_PREVIO=
JWT_ISSUER=smid-auth
JWT_AUDIENCE=smid-servicios

# --- Autorización: roles que habilitan ESCRITURAS sobre datos de referencia ---
ROLES_ADMIN=ADMIN_INSTITUCIONES,COORDINACION_NACIONAL

# --- Eventos de dominio: log (por defecto) | rabbitmq ---
EVENTOS_TRANSPORTE=log

# --- RabbitMQ (solo si EVENTOS_TRANSPORTE=rabbitmq) ---
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=smid
RABBIT_PASSWORD=cambiar_esta_clave
RABBIT_VHOST=/
