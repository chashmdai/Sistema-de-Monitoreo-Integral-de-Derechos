# =============================================================================
# Variables de entorno de antecedentes-service (SMID 6.8)
# Copiar a `.env` y completar. NUNCA commitear `.env` con valores reales.
# =============================================================================

# --- Servidor ---
SERVER_PORT=8094

# --- Base de datos MySQL 8 ---
# tinyInt1isBit=true es obligatorio (TINYINT(1) -> boolean).
DB_URL=jdbc:mysql://localhost:3306/db_antecedentes?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8&tinyInt1isBit=true
DB_USER=smid
DB_PASSWORD=cambiar

# --- JWT (HS256) ---
# JWT_SECRET se comparte BYTE A BYTE con el Gateway. Minimo 32 bytes para HS256.
JWT_KID_ACTIVO=smid-hs256-1
JWT_SECRET=reemplazar-por-un-secreto-de-al-menos-32-bytes
# Rotacion (opcional): clave previa aceptada en validacion.
JWT_KID_PREVIO=
JWT_SECRET_PREVIO=
JWT_ISSUER=smid-auth
JWT_AUDIENCE=smid-servicios

# --- Roles (CSV) ---
ROLES_REVISION=JEFATURA_UNIDAD,COORDINACION_NACIONAL
ROLES_ADMIN=ADMINISTRADOR,COORDINACION_NACIONAL

# --- Cifrado del relato ---
# aes-gcm (produccion) | none (passthrough, solo desarrollo).
CIFRADO_RELATO=aes-gcm
# Clave AES-256 en Base64 (32 bytes). Obligatoria si CIFRADO_RELATO=aes-gcm.
# Generar, por ejemplo, con: openssl rand -base64 32
ANTECEDENTES_CIFRADO_CLAVE=

# --- Eventos de dominio ---
# log (por defecto) | rabbitmq.
EVENTOS_TRANSPORTE=log

# --- RabbitMQ (solo si EVENTOS_TRANSPORTE=rabbitmq) ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=smid
RABBITMQ_PASSWORD=cambiar
RABBITMQ_VHOST=/

# --- Logging ---
LOG_LEVEL=INFO
