# ============================================================================
# personas-service (6.2) · Variables de entorno (plantilla)
# ----------------------------------------------------------------------------
# Copiar a `.env` y completar. NUNCA versionar el archivo `.env` real.
# Los secretos JWT deben coincidir con los de Identidad (6.1): el servicio
# revalida el token con la misma clave HMAC.
# ============================================================================

# ----- Base de datos (MySQL 8) -----
# La URL incluye la zona horaria UTC y utf8; ajustar host/puerto/credenciales.
DB_URL=jdbc:mysql://localhost:3306/db_personas?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=utf8
DB_USER=smid
DB_PASSWORD=cambiar_esta_clave

# ----- JWT (validación del token, defensa en profundidad) -----
# Emisor y audiencia esperados (deben calzar con los que emite auth-service).
JWT_ISSUER=smid-auth
JWT_AUDIENCE=smid-servicios
# Clave de firma ACTIVA. El secreto se usa como clave HMAC desde sus bytes UTF-8:
# debe tener AL MENOS 32 bytes (HS256). 'kid' identifica la clave en el token.
JWT_KID=smid-key-1
JWT_SECRET=defina_un_secreto_de_al_menos_32_bytes_aqui_0123456789
# Clave PREVIA (opcional): habilita rotación sin invalidar tokens en vuelo.
# Dejar en blanco si no se usa rotación.
JWT_KID_PREVIO=
JWT_SECRET_PREVIO=

# ----- Mensajería de eventos -----
# Transporte de los eventos de dominio hacia Auditoría:
#   log      -> registra el evento como JSON (no requiere RabbitMQ).
#   rabbitmq -> publica en el exchange 'smid.eventos'.
EVENTOS_TRANSPORTE=log
# Sólo necesario si EVENTOS_TRANSPORTE=rabbitmq:
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
