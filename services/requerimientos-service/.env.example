# ============================================================================
#  requerimientos-service (6.3) — variables de entorno (ejemplo)
#  Copiar a .env y completar. NUNCA versionar el .env real con secretos.
# ============================================================================

# --- Servidor ---
SERVER_PORT=8089

# --- Base de datos MySQL 8 (esquema db_requerimientos; Flyway lo crea vacío) ---
DB_URL=jdbc:mysql://localhost:3306/db_requerimientos?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
DB_USER=smid_req
DB_PASSWORD=cambia_esta_clave

# --- JWT (defensa en profundidad, HS256 con kid). El secreto debe tener >= 32 bytes. ---
JWT_ISSUER=smid-auth
JWT_AUDIENCE=smid-servicios
JWT_KID=smid-2026-06
JWT_SECRET=clave-hs256-de-al-menos-32-bytes-cambia-esto-0123456789
# Ventana de rotación (opcional): si se define, se acepta también la firma con la clave previa.
JWT_KID_PREVIO=
JWT_SECRET_PREVIO=

# --- Eventos de dominio ---
# 'log' (por defecto) o 'rabbitmq'
EVENTOS_TRANSPORTE=log
EVENTOS_EXCHANGE=smid.eventos

# --- Folio: corte de la serie BETA -> OFICIAL (la oficial arranca inmaculada desde 1) ---
FOLIO_INICIO_OFICIAL=2027-01-01
# Código de sede de respaldo cuando no hay mapeo configurado para el alt_key de la sede.
SEDE_CODIGO_DEFECTO=SED

# --- Integración servicio a servicio ---
PERSONAS_URL=http://localhost:8088
CATALOGO_URL=http://localhost:8087
IDENTIDAD_URL=http://localhost:8081
# 'permisiva' (tolera Identidad no disponible) o 'estricta'
VERIFICACION_PROFESIONAL=permisiva

# --- Autorización: roles que conceden la facultad de Coordinación (CSV) ---
ROLES_COORDINACION=COORDINADOR,COORDINACION,ADMIN_SEDE,ADMIN_NACIONAL

# --- RabbitMQ (solo si EVENTOS_TRANSPORTE=rabbitmq) ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
