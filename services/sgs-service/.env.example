# ============================================================================
# sgs-service (legado IA) · Variables de entorno (plantilla)
# ----------------------------------------------------------------------------
# Copiar a `.env` y completar. NUNCA versionar el `.env` real.
# JWT_SECRET debe ser IDÉNTICO al del resto del ecosistema (lo valida el Doctor).
#
# Esquema gestionado por Flyway (V1__inicial.sql). En BD vacía crea las tablas;
# en BD poblada hace baseline. Hibernate solo valida (ddl-auto=validate).
# ============================================================================

# ----- Servidor -----
SERVER_PORT=8083

# ----- Base de datos (MySQL 8) -----
DB_URL=jdbc:mysql://localhost:3306/db_sgs?useUnicode=true&characterEncoding=utf8&serverTimezone=America/Santiago
DB_USER=smid
DB_PASSWORD=
JPA_DDL_AUTO=validate

# ----- JWT (HS256 compartido con smid-auth, defensa en profundidad) -----
JWT_SECRET=
JWT_CLAIM_ROLES=roles

# ----- OpenAI (OBLIGATORIO: motor IA) -----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODELO_EXTRACCION=gpt-5-mini
OPENAI_MODELO_EVALUACION=gpt-5.5

# ----- MinIO (almacenamiento de expedientes) -----
MINIO_ENABLED=true
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=sgs-expedientes

# ----- RabbitMQ -----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=

# ----- Telegram (notificación de alertas, opcional) -----
TELEGRAM_ENABLED=false
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
