# ============================================================================
# esnna-service (legado IA) · Variables de entorno (plantilla)
# ----------------------------------------------------------------------------
# Copiar a `.env` y completar. NUNCA versionar el `.env` real.
# JWT_SECRET debe ser IDÉNTICO al del resto del ecosistema (lo valida el Doctor).
# ============================================================================

# ----- Servidor -----
SERVER_PORT=8086

# ----- Base de datos (MySQL 8) -----
DB_URL=jdbc:mysql://localhost:3306/db_esnna?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Santiago&characterEncoding=utf8
DB_USER=smid
DB_PASSWORD=
# Este servicio legado deja que Hibernate cree el esquema (no usa Flyway).
JPA_DDL_AUTO=update

# ----- JWT (HS256 compartido con smid-auth, defensa en profundidad) -----
JWT_SECRET=
# Emisor/audiencia: vacío = no se validan. El emisor real es smid-auth y la
# audiencia smid-servicios; pueden activarse aquí si se desea endurecer.
JWT_ISSUER=
JWT_AUDIENCE=
JWT_CLAIM_ROLES=roles

# ----- OpenAI (OBLIGATORIO: motor IA) -----
OPENAI_API_KEY=
OPENAI_MODELO_EXTRACCION=gpt-4o-mini
OPENAI_MODELO_CONSOLIDACION=gpt-5.5

# ----- MinIO (respaldo de PDFs, opcional) -----
MINIO_ENABLED=false
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=esnna-documentos
