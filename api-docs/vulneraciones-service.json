{"openapi":"3.1.0","info":{"title":"SMID - Vulneraciones y FIR API","description":"Gestión de Ficha Interna Reservada, vulneraciones y antecedentes reservados","version":"1.0.0"},"servers":[{"url":"http://localhost:8091","description":"Generated server url"}],"security":[{"bearerAuth":[]}],"tags":[{"name":"Vulneraciones y FIR","description":"Ficha Interna Reservada, vulneraciones y antecedentes reservados."}],"paths":{"/vulneraciones/fichas/{altKey}/vulneraciones":{"post":{"tags":["Vulneraciones y FIR"],"summary":"Registra una vulneración en la FIR","description":"Registra una vulneración durante la ventana mutable de la FIR. Solo se admiten fichas en\nEN_ELABORACION; fuera de esa ventana responde VUL-409. Los textos son reservados y se cifran\nen reposo según configuración.\n","operationId":"registrarVulneracion","parameters":[{"name":"altKey","in":"path","description":"Identificador opaco de la FIR.","required":true,"schema":{"type":"string"},"example":"5f1e36b4-4a38-4c7c-bfb7-cc3ed16cc9b1"}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RegistrarVulneracionRequest"},"example":{"idDerechoAlt":"2e7f7e7d-2f0d-41a5-bc9c-98d0a4bd32b5","idCausaAlt":"6a0df156-9898-4e8e-9cf4-214f1b138a4a","idNnaAlt":"d8d4c0c9-ec8e-49f2-b1c3-0d0f1f6b66a1","gravedad":"GRAVE","relato":"Texto reservado sintético para pruebas.","fechaHecho":"2027-04-20"}}},"required":true},"responses":{"201":{"description":"Vulneración registrada","content":{"*/*":{"schema":{"$ref":"#/components/schemas/VulneracionResponse"}}}},"400":{"description":"VUL-001 - Solicitud inválida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"AUTZ-003 - No autenticado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"AUTZ-004 - Sin rol suficiente","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"VUL-404 - No existe o fuera de alcance territorial","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"409":{"description":"VUL-409 - Ficha no mutable o conflicto","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"422":{"description":"VUL-422 - Regla de negocio incumplida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"VUL-500 - Error interno","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/vulneraciones/fichas/{altKey}/transiciones":{"post":{"tags":["Vulneraciones y FIR"],"summary":"Transiciona una FIR","description":"Aplica transiciones administrativas CERRAR o REABRIR. Ambas requieren rol de Coordinación.\nMATERIALIZACION es una pseudo-acción de sistema y no es invocable por API.\n","operationId":"transicionar","parameters":[{"name":"altKey","in":"path","description":"Identificador opaco de la FIR.","required":true,"schema":{"type":"string"},"example":"5f1e36b4-4a38-4c7c-bfb7-cc3ed16cc9b1"}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/TransicionRequest"},"example":{"accion":"CERRAR","observacion":"Cierre administrativo sintético."}}},"required":true},"responses":{"200":{"description":"Ficha transicionada","content":{"*/*":{"schema":{"$ref":"#/components/schemas/FichaDetalleResponse"}}}},"400":{"description":"VUL-001 - Solicitud inválida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"AUTZ-003 - No autenticado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"AUTZ-004 - Sin rol de Coordinación","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"VUL-404 - No existe o fuera de alcance territorial","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"409":{"description":"VUL-409 - Transición inválida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"422":{"description":"VUL-422 - Regla de negocio incumplida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"VUL-500 - Error interno","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/vulneraciones/fichas/{altKey}/antecedentes":{"post":{"tags":["Vulneraciones y FIR"],"summary":"Registra un antecedente reservado","description":"Registra un antecedente en la FIR durante la ventana mutable. La descripción es reservada y\npuede mostrarse redactada en respuestas generales según el rol.\n","operationId":"registrarAntecedente","parameters":[{"name":"altKey","in":"path","description":"Identificador opaco de la FIR.","required":true,"schema":{"type":"string"},"example":"5f1e36b4-4a38-4c7c-bfb7-cc3ed16cc9b1"}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RegistrarAntecedenteRequest"},"example":{"tipo":"ESCOLAR","descripcion":"Descripción reservada sintética para pruebas.","fecha":"2027-03-15","fuente":"Fuente institucional sintética"}}},"required":true},"responses":{"201":{"description":"Antecedente registrado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/AntecedenteResponse"}}}},"400":{"description":"VUL-001 - Solicitud inválida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"AUTZ-003 - No autenticado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"AUTZ-004 - Sin rol suficiente","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"VUL-404 - No existe o fuera de alcance territorial","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"409":{"description":"VUL-409 - Ficha no mutable o conflicto","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"422":{"description":"VUL-422 - Regla de negocio incumplida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"VUL-500 - Error interno","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/vulneraciones/fichas":{"get":{"tags":["Vulneraciones y FIR"],"summary":"Lista FIR paginadas","description":"Lista fichas dentro del alcance territorial del usuario autenticado.\nPermite filtrar por caso de origen y estado. Estados: EN_ELABORACION y CERRADA.\n","operationId":"listar","parameters":[{"name":"idCaso","in":"query","description":"Identificador opaco del caso asociado.","required":false,"schema":{"type":"string"},"example":"7d6b3c3c-9d22-4b10-8d3d-1f3900c13f20"},{"name":"estado","in":"query","description":"Estado de la FIR.","required":false,"schema":{"type":"string","enum":["EN_ELABORACION","CERRADA"]},"example":"EN_ELABORACION"},{"name":"pagina","in":"query","description":"Número de página, base cero.","required":false,"schema":{"type":"integer","format":"int32","default":0},"example":0},{"name":"tamano","in":"query","description":"Tamaño de página.","required":false,"schema":{"type":"integer","format":"int32","default":20},"example":20}],"responses":{"200":{"description":"Página de fichas","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PaginaResponse"}}}},"400":{"description":"VUL-001 - Solicitud inválida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"401":{"description":"AUTZ-003 - No autenticado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"VUL-500 - Error interno","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/vulneraciones/fichas/{altKey}":{"get":{"tags":["Vulneraciones y FIR"],"summary":"Obtiene el detalle de una FIR","description":"Retorna la Ficha Interna Reservada por identificador opaco dentro del alcance territorial.\nLa FIR no se crea por API: nace por el evento caso.abierto. El contenido reservado puede\nvenir redactado según el rol del usuario. Si no existe o está fuera de alcance territorial,\nresponde VUL-404.\n","operationId":"detalle","parameters":[{"name":"altKey","in":"path","description":"Identificador opaco de la FIR.","required":true,"schema":{"type":"string"},"example":"5f1e36b4-4a38-4c7c-bfb7-cc3ed16cc9b1"}],"responses":{"200":{"description":"Ficha encontrada","content":{"*/*":{"schema":{"$ref":"#/components/schemas/FichaDetalleResponse"}}}},"401":{"description":"AUTZ-003 - No autenticado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"AUTZ-004 - Sin rol suficiente","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"VUL-404 - No existe o fuera de alcance territorial","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"VUL-500 - Error interno","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/vulneraciones/fichas/{altKey}/reservado":{"get":{"tags":["Vulneraciones y FIR"],"summary":"Obtiene contenido reservado de una FIR","description":"Retorna relatos y descripciones reservadas en claro solo para roles habilitados.\nEn el detalle general el contenido puede venir redactado; este endpoint requiere rol de\nacceso reservado. No usar ejemplos con nombres, RUT ni relatos reales.\n","operationId":"reservado","parameters":[{"name":"altKey","in":"path","description":"Identificador opaco de la FIR.","required":true,"schema":{"type":"string"},"example":"5f1e36b4-4a38-4c7c-bfb7-cc3ed16cc9b1"}],"responses":{"200":{"description":"Contenido reservado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ContenidoReservadoResponse"}}}},"401":{"description":"AUTZ-003 - No autenticado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"403":{"description":"AUTZ-004 - Sin rol de acceso reservado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"404":{"description":"VUL-404 - No existe o fuera de alcance territorial","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}},"500":{"description":"VUL-500 - Error interno","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ErrorResponse"}}}}},"security":[{"bearerAuth":[]}]}}},"components":{"schemas":{"RegistrarVulneracionRequest":{"type":"object","description":"Solicitud para registrar una vulneración en una FIR.","properties":{"idDerechoAlt":{"type":"string","description":"Identificador opaco del derecho vulnerado.","example":"2e7f7e7d-2f0d-41a5-bc9c-98d0a4bd32b5","minLength":1},"idCausaAlt":{"type":"string","description":"Identificador opaco de la causa asociada, si aplica.","example":"6a0df156-9898-4e8e-9cf4-214f1b138a4a"},"idNnaAlt":{"type":"string","description":"Identificador opaco del NNA afectado.","example":"d8d4c0c9-ec8e-49f2-b1c3-0d0f1f6b66a1","minLength":1},"gravedad":{"type":"string","description":"Gravedad de la vulneración.","enum":["LEVE","MEDIA","GRAVE","GRAVISIMA"],"example":"GRAVE","minLength":1},"relato":{"type":"string","description":"Relato reservado sintético. No incluir datos reales en ejemplos.","example":"Texto reservado sintético para pruebas."},"fechaHecho":{"type":"string","format":"date","description":"Fecha del hecho.","example":"2027-04-20"}},"required":["gravedad","idDerechoAlt","idNnaAlt"]},"VulneracionResponse":{"type":"object","description":"Vulneración registrada en una FIR.","properties":{"altKey":{"type":"string","description":"Identificador opaco de la vulneración.","example":"31abf51b-badf-4a3d-b2a7-1a37089e1370"},"idDerechoAlt":{"type":"string","description":"Identificador opaco del derecho vulnerado.","example":"2e7f7e7d-2f0d-41a5-bc9c-98d0a4bd32b5"},"idCausaAlt":{"type":"string","description":"Identificador opaco de la causa asociada, si aplica.","example":"6a0df156-9898-4e8e-9cf4-214f1b138a4a"},"idNnaAlt":{"type":"string","description":"Identificador opaco del NNA afectado.","example":"d8d4c0c9-ec8e-49f2-b1c3-0d0f1f6b66a1"},"nnaNombreLegible":{"type":"string","description":"Etiqueta legible sintética del NNA cuando el enriquecimiento está disponible.","example":"NNA registrado"},"etiquetaDerecho":{"type":"string","description":"Etiqueta del derecho desde catálogo, si está disponible.","example":"Derecho sintético"},"etiquetaCausa":{"type":"string","description":"Etiqueta de la causa desde catálogo, si está disponible.","example":"Causa sintética"},"gravedad":{"type":"string","description":"Gravedad de la vulneración.","enum":["LEVE","MEDIA","GRAVE","GRAVISIMA"],"example":"GRAVE"},"relato":{"type":"string","description":"Relato reservado. Puede omitirse o venir redactado según rol.","example":"Texto reservado sintético para pruebas."},"fechaHecho":{"type":"string","format":"date","description":"Fecha del hecho.","example":"2027-04-20"},"registradoEn":{"type":"string","format":"date-time","description":"Instante de registro en UTC.","example":"2027-05-01T12:00:00Z"},"registradoPor":{"type":"string","description":"Identificador opaco del actor que registró la vulneración.","example":"c27f4500-f412-4fd1-86a8-6caa5933583b"}}},"ErrorResponse":{"type":"object","description":"Sobre de error unificado del ecosistema SMID.","properties":{"status":{"type":"integer","format":"int32","description":"Código HTTP numérico.","example":404},"error":{"type":"string","description":"Frase HTTP.","example":"Not Found"},"codigo":{"type":"string","description":"Código estable del error.","enum":["AUTZ-003","AUTZ-004","VUL-001","VUL-404","VUL-409","VUL-422","VUL-500"],"example":"VUL-404"},"mensaje":{"type":"string","description":"Mensaje legible para el consumidor.","example":"No existe una ficha accesible con el identificador indicado."},"detalles":{"type":"array","description":"Detalles de validación, si aplica.","example":["gravedad: La gravedad es obligatoria."],"items":{"type":"string"}},"ruta":{"type":"string","description":"Ruta solicitada.","example":"/vulneraciones/fichas/5f1e36b4-4a38-4c7c-bfb7-cc3ed16cc9b1"},"timestamp":{"type":"string","format":"date-time","description":"Instante UTC del error.","example":"2027-05-01T12:00:00Z"}}},"TransicionRequest":{"type":"object","description":"Solicitud de transición administrativa de una FIR. Requiere rol de Coordinación.","properties":{"accion":{"type":"string","description":"Acción administrativa a aplicar.","enum":["CERRAR","REABRIR"],"example":"CERRAR","minLength":1},"observacion":{"type":"string","description":"Observación sintética asociada a la transición.","example":"Cierre administrativo sintético."}},"required":["accion"]},"AntecedenteResponse":{"type":"object","description":"Antecedente reservado asociado a una FIR.","properties":{"altKey":{"type":"string","description":"Identificador opaco del antecedente.","example":"31abf51b-badf-4a3d-b2a7-1a37089e1370"},"tipo":{"type":"string","description":"Tipo del antecedente.","enum":["DERIVACION","PERICIA","ANTECEDENTE_FAMILIAR","ESCOLAR","SALUD","OTRO"],"example":"ESCOLAR"},"descripcion":{"type":"string","description":"Descripción reservada. Puede omitirse o venir redactada según rol.","example":"Descripción reservada sintética para pruebas."},"fecha":{"type":"string","format":"date","description":"Fecha del antecedente.","example":"2027-03-15"},"fuente":{"type":"string","description":"Fuente sintética o institucional del antecedente.","example":"Fuente institucional sintética"},"registradoEn":{"type":"string","format":"date-time","description":"Instante de registro en UTC.","example":"2027-05-01T12:00:00Z"},"registradoPor":{"type":"string","description":"Identificador opaco del actor que registró el antecedente.","example":"c27f4500-f412-4fd1-86a8-6caa5933583b"}}},"EnriquecimientoResponse":{"type":"object","description":"Enriquecimiento on-demand contra Casos, best-effort.","properties":{"disponible":{"type":"boolean","description":"Indica si el enriquecimiento remoto estuvo disponible.","example":false},"estadoCaso":{"type":"string","description":"Estado sintético del caso asociado si el enriquecimiento está disponible.","example":"ABIERTO"},"numeroExpedienteVigente":{"type":"string","description":"Número de expediente vigente si el enriquecimiento está disponible.","example":"EXP-RM-1/2027"}}},"FichaDetalleResponse":{"type":"object","description":"Detalle de una Ficha Interna Reservada. Expone solo identificadores opacos.","properties":{"altKey":{"type":"string","description":"Identificador opaco de la FIR.","example":"5f1e36b4-4a38-4c7c-bfb7-cc3ed16cc9b1"},"numeroFicha":{"type":"string","description":"Número institucional de la FIR.","example":"FIR-RM-1/2027"},"idCasoAlt":{"type":"string","description":"Identificador opaco del caso asociado.","example":"7d6b3c3c-9d22-4b10-8d3d-1f3900c13f20"},"numeroExpediente":{"type":"string","description":"Número de expediente del caso asociado.","example":"EXP-RM-1/2027"},"estado":{"type":"string","description":"Estado actual de la FIR.","enum":["EN_ELABORACION","CERRADA"],"example":"EN_ELABORACION"},"complejidad":{"type":"string","description":"Complejidad asociada.","example":"ALTA"},"idSedeAlt":{"type":"string","description":"Identificador opaco de la sede.","example":"11111111-1111-1111-1111-111111111111"},"idUnidadAlt":{"type":"string","description":"Identificador opaco de la unidad.","example":"4f86e9a4-2924-41d7-bf27-6ef13b6f6b9a"},"esBeta":{"type":"boolean","description":"Indica si pertenece a serie beta.","example":false},"abiertaEn":{"type":"string","format":"date-time","description":"Instante de apertura en UTC.","example":"2027-05-01T12:00:00Z"},"cerradaEn":{"type":"string","format":"date-time","description":"Instante de cierre en UTC, nulo si sigue en elaboración.","example":"2027-06-01T12:00:00Z"},"creadaEn":{"type":"string","format":"date-time","description":"Instante de creación en UTC.","example":"2027-05-01T12:00:00Z"},"actualizadaEn":{"type":"string","format":"date-time","description":"Instante de última actualización en UTC.","example":"2027-05-02T10:30:00Z"},"reservadoOculto":{"type":"boolean","description":"Indica que relatos/descripciones fueron ocultados por falta de rol reservado.","example":true},"enriquecimiento":{"$ref":"#/components/schemas/EnriquecimientoResponse"},"vulneraciones":{"type":"array","description":"Vulneraciones registradas en la FIR.","items":{"$ref":"#/components/schemas/VulneracionResponse"}},"antecedentes":{"type":"array","description":"Antecedentes reservados registrados en la FIR.","items":{"$ref":"#/components/schemas/AntecedenteResponse"}},"historial":{"type":"array","description":"Historial de materialización y transiciones.","items":{"$ref":"#/components/schemas/TransicionResponse"}}}},"TransicionResponse":{"type":"object","description":"Asiento del historial de materialización y transiciones de la FIR.","properties":{"altKey":{"type":"string","description":"Identificador opaco del asiento de historial.","example":"afcf2d25-190c-4e37-aef8-9dd1543d29b0"},"estadoOrigen":{"type":"string","description":"Estado origen. Nulo en la materialización inicial.","enum":["EN_ELABORACION","CERRADA"],"example":"EN_ELABORACION"},"estadoDestino":{"type":"string","description":"Estado destino.","enum":["EN_ELABORACION","CERRADA"],"example":"CERRADA"},"accion":{"type":"string","description":"Acción aplicada. MATERIALIZACION es de sistema, no invocable por API.","enum":["MATERIALIZACION","CERRAR","REABRIR"],"example":"CERRAR"},"observacion":{"type":"string","description":"Observación sintética de la transición.","example":"Cierre administrativo sintético."},"actorAlt":{"type":"string","description":"Identificador opaco del actor.","example":"c27f4500-f412-4fd1-86a8-6caa5933583b"},"ocurridoEn":{"type":"string","format":"date-time","description":"Instante UTC de la transición.","example":"2027-05-01T12:00:00Z"}}},"RegistrarAntecedenteRequest":{"type":"object","description":"Solicitud para registrar un antecedente reservado en una FIR.","properties":{"tipo":{"type":"string","description":"Tipo del antecedente.","enum":["DERIVACION","PERICIA","ANTECEDENTE_FAMILIAR","ESCOLAR","SALUD","OTRO"],"example":"ESCOLAR","minLength":1},"descripcion":{"type":"string","description":"Descripción reservada sintética. No incluir datos reales en ejemplos.","example":"Descripción reservada sintética para pruebas."},"fecha":{"type":"string","format":"date","description":"Fecha del antecedente.","example":"2027-03-15"},"fuente":{"type":"string","description":"Fuente sintética o institucional del antecedente.","example":"Fuente institucional sintética"}},"required":["tipo"]},"PaginaResponse":{"type":"object","description":"Página de resultados de la API.","properties":{"contenido":{"type":"array","description":"Contenido de la página.","items":{}},"pagina":{"type":"integer","format":"int32","description":"Número de página, base cero.","example":0},"tamano":{"type":"integer","format":"int32","description":"Tamaño de página solicitado.","example":20},"total":{"type":"integer","format":"int64","description":"Total de elementos encontrados.","example":42}}},"ContenidoReservadoResponse":{"type":"object","description":"Contenido reservado en claro de una FIR, disponible solo para roles habilitados.","properties":{"fichaAltKey":{"type":"string","description":"Identificador opaco de la FIR.","example":"5f1e36b4-4a38-4c7c-bfb7-cc3ed16cc9b1"},"relatos":{"type":"array","description":"Relatos reservados de vulneraciones.","items":{"$ref":"#/components/schemas/ItemReservadoResponse"}},"descripciones":{"type":"array","description":"Descripciones reservadas de antecedentes.","items":{"$ref":"#/components/schemas/ItemReservadoResponse"}}}},"ItemReservadoResponse":{"type":"object","description":"Ítem de contenido reservado en claro.","properties":{"altKey":{"type":"string","description":"Identificador opaco del elemento que contiene el texto reservado.","example":"31abf51b-badf-4a3d-b2a7-1a37089e1370"},"texto":{"type":"string","description":"Texto reservado sintético. En producción no usar datos reales en ejemplos.","example":"Texto reservado sintético para pruebas."}}}},"securitySchemes":{"bearerAuth":{"type":"http","description":"JWT Bearer emitido por smid-auth.","scheme":"bearer","bearerFormat":"JWT"}}}}