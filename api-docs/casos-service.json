{"openapi":"3.1.0","info":{"title":"SMID - Casos API","description":"Gestión del expediente institucional que nace desde un requerimiento asignado","version":"1.0.0"},"servers":[{"url":"http://localhost:8090","description":"Generated server url"}],"security":[{"bearerAuth":[]}],"tags":[{"name":"Casos","description":"Gestión del expediente institucional nacido desde requerimientos asignados."}],"paths":{"/casos/{altKey}/transiciones":{"post":{"tags":["Casos"],"summary":"Transiciona el estado de un caso","description":"Aplica una acción válida según la máquina de estados del expediente.\nAcciones: INICIAR_INVESTIGACION, DERIVAR_A_SEGUIMIENTO, SUSPENDER, REANUDAR,\nCERRAR, REABRIR y ARCHIVAR. CERRAR, REABRIR y ARCHIVAR requieren rol de Coordinación.\nUna transición no permitida para el estado actual responde CAS-409.\n","operationId":"transicionar","parameters":[{"name":"altKey","in":"path","description":"Identificador opaco del caso.","required":true,"schema":{"type":"string"},"example":"7d6b3c3c-9d22-4b10-8d3d-1f3900c13f20"}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/TransicionDTO"},"example":{"accion":"INICIAR_INVESTIGACION","observacion":"Inicio de investigación institucional."}}},"required":true},"responses":{"200":{"description":"Caso transicionado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/CasoDetalleDTO"}}}},"400":{"description":"CAS-001 - Solicitud inválida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"401":{"description":"AUTZ-003 - No autenticado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"403":{"description":"AUTZ-004 - Sin rol de Coordinación","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"404":{"description":"CAS-404 - No existe o fuera de alcance territorial","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"409":{"description":"CAS-409 - Transición inválida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"422":{"description":"CAS-422 - Regla de negocio incumplida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"500":{"description":"CAS-500 - Error interno","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}}},"security":[{"bearerAuth":[]}]}},"/casos":{"get":{"tags":["Casos"],"summary":"Lista casos paginados","description":"Lista casos dentro del alcance territorial del usuario autenticado.\nPermite filtrar por estado y por unidad usando identificadores opacos.\nEstados: ABIERTO, EN_INVESTIGACION, EN_SEGUIMIENTO, SUSPENDIDO, CERRADO, ARCHIVADO.\n","operationId":"listar","parameters":[{"name":"estado","in":"query","description":"Estado del caso.","required":false,"schema":{"type":"string","enum":["ABIERTO","EN_INVESTIGACION","EN_SEGUIMIENTO","SUSPENDIDO","CERRADO","ARCHIVADO"]},"example":"ABIERTO"},{"name":"unidad","in":"query","description":"Identificador opaco de la unidad.","required":false,"schema":{"type":"string"},"example":"4f86e9a4-2924-41d7-bf27-6ef13b6f6b9a"},{"name":"pagina","in":"query","description":"Número de página, base cero.","required":false,"schema":{"type":"integer","format":"int32","default":0},"example":0},{"name":"tamano","in":"query","description":"Tamaño de página.","required":false,"schema":{"type":"integer","format":"int32","default":20},"example":20}],"responses":{"200":{"description":"Página de casos","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PaginaDTO"}}}},"400":{"description":"CAS-001 - Solicitud inválida","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"401":{"description":"AUTZ-003 - No autenticado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"500":{"description":"CAS-500 - Error interno","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}}},"security":[{"bearerAuth":[]}]}},"/casos/{altKey}":{"get":{"tags":["Casos"],"summary":"Obtiene el detalle de un caso","description":"Retorna el expediente por identificador opaco dentro del alcance territorial del usuario.\nSi el caso no existe o está fuera del alcance territorial, responde CAS-404.\nNo existe endpoint de creación manual: los casos nacen por eventos requerimiento.asignado.\n","operationId":"obtener","parameters":[{"name":"altKey","in":"path","description":"Identificador opaco del caso.","required":true,"schema":{"type":"string"},"example":"7d6b3c3c-9d22-4b10-8d3d-1f3900c13f20"},{"name":"Authorization","in":"header","required":false,"schema":{"type":"string"}}],"responses":{"200":{"description":"Caso encontrado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/CasoDetalleDTO"}}}},"401":{"description":"AUTZ-003 - No autenticado","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"403":{"description":"AUTZ-004 - Sin rol requerido","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"404":{"description":"CAS-404 - No existe o fuera de alcance territorial","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}},"500":{"description":"CAS-500 - Error interno","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SobreError"}}}}},"security":[{"bearerAuth":[]}]}}},"components":{"schemas":{"TransicionDTO":{"type":"object","description":"Solicitud de transición de estado. CERRAR, REABRIR y ARCHIVAR requieren rol de Coordinación.\nLas demás acciones son operativas y requieren alcance territorial sobre el caso.\n","properties":{"accion":{"type":"string","description":"Acción a aplicar sobre el caso.","enum":["INICIAR_INVESTIGACION","DERIVAR_A_SEGUIMIENTO","SUSPENDER","REANUDAR","CERRAR","REABRIR","ARCHIVAR"],"example":"INICIAR_INVESTIGACION","minLength":1},"observacion":{"type":"string","description":"Observación opcional de la transición.","example":"Inicio de investigación institucional.","maxLength":2000,"minLength":0}},"required":["accion"]},"CasoDetalleDTO":{"type":"object","description":"Detalle completo de un caso institucional. Expone solo identificadores opacos.","properties":{"altKey":{"type":"string","description":"Identificador opaco del caso.","example":"7d6b3c3c-9d22-4b10-8d3d-1f3900c13f20"},"numeroExpediente":{"type":"string","description":"Número institucional del expediente.","example":"EXP-RM-1/2027"},"idRequerimientoOrigen":{"type":"string","description":"Identificador opaco del requerimiento que originó el caso.","example":"1e19d2cc-7c5c-4b48-9d5d-e8aef42e4f71"},"folioRequerimiento":{"type":"string","description":"Folio del requerimiento de origen.","example":"F-100"},"estado":{"type":"string","description":"Estado actual del expediente.","enum":["ABIERTO","EN_INVESTIGACION","EN_SEGUIMIENTO","SUSPENDIDO","CERRADO","ARCHIVADO"],"example":"ABIERTO"},"complejidad":{"type":"string","description":"Complejidad heredada del requerimiento.","example":"MEDIANA"},"idSede":{"type":"string","description":"Identificador opaco de la sede.","example":"11111111-1111-1111-1111-111111111111"},"idUnidad":{"type":"string","description":"Identificador opaco de la unidad.","example":"4f86e9a4-2924-41d7-bf27-6ef13b6f6b9a"},"idProfesionalResponsable":{"type":"string","description":"Identificador opaco del profesional responsable.","example":"c27f4500-f412-4fd1-86a8-6caa5933583b"},"requiereFichaReservada":{"type":"boolean","description":"Indica si el expediente requiere ficha reservada.","example":false},"esBeta":{"type":"boolean","description":"Indica si pertenece a serie beta.","example":false},"abiertoEn":{"type":"string","format":"date-time","description":"Fecha de apertura en UTC.","example":"2027-02-01T10:00:00Z"},"cerradoEn":{"type":"string","format":"date-time","description":"Fecha de cierre en UTC, nula si sigue activo.","example":"2027-03-10T15:30:00Z"},"creadoEn":{"type":"string","format":"date-time","description":"Fecha de creación del registro en UTC.","example":"2027-02-01T10:00:00Z"},"actualizadoEn":{"type":"string","format":"date-time","description":"Fecha de última actualización en UTC.","example":"2027-02-05T12:15:00Z"},"enriquecimiento":{"$ref":"#/components/schemas/EnriquecimientoDTO"},"historial":{"type":"array","description":"Historial de materialización y transiciones del caso.","items":{"$ref":"#/components/schemas/HistorialTransicionDTO"}}}},"EnriquecimientoDTO":{"type":"object","description":"Datos de enriquecimiento on-demand del requerimiento de origen.","properties":{"disponible":{"type":"boolean","description":"Indica si el enriquecimiento remoto estuvo disponible.","example":false},"estadoRequerimiento":{"type":"string","description":"Estado del requerimiento de origen cuando el enriquecimiento está disponible.","example":"ASIGNADO"},"canal":{"type":"string","description":"Canal de ingreso del requerimiento de origen.","example":"WEB"},"cantidadNnaAfectados":{"type":"integer","format":"int32","description":"Cantidad referencial de NNA afectados.","example":2}}},"HistorialTransicionDTO":{"type":"object","description":"Asiento del historial de materialización y transiciones del caso.","properties":{"altKey":{"type":"string","description":"Identificador opaco del asiento de historial.","example":"afcf2d25-190c-4e37-aef8-9dd1543d29b0"},"estadoOrigen":{"type":"string","description":"Estado origen. Es nulo en la materialización inicial.","enum":["ABIERTO","EN_INVESTIGACION","EN_SEGUIMIENTO","SUSPENDIDO","CERRADO","ARCHIVADO"],"example":"ABIERTO"},"estadoDestino":{"type":"string","description":"Estado destino del asiento.","enum":["ABIERTO","EN_INVESTIGACION","EN_SEGUIMIENTO","SUSPENDIDO","CERRADO","ARCHIVADO"],"example":"EN_INVESTIGACION"},"accion":{"type":"string","description":"Acción aplicada. MATERIALIZACION registra el nacimiento por evento.","enum":["MATERIALIZACION","INICIAR_INVESTIGACION","DERIVAR_A_SEGUIMIENTO","SUSPENDER","REANUDAR","CERRAR","REABRIR","ARCHIVAR"],"example":"MATERIALIZACION"},"observacion":{"type":"string","description":"Observación asociada al asiento.","example":"Caso materializado desde requerimiento asignado."},"actor":{"type":"string","description":"Identificador opaco del actor. En materialización usa actor de sistema.","example":"00000000-0000-0000-0000-000000000000"},"ocurridoEn":{"type":"string","format":"date-time","description":"Instante UTC de la transición.","example":"2027-02-01T10:00:00Z"}}},"SobreError":{"type":"object","description":"Sobre de error unificado del ecosistema SMID.","properties":{"status":{"type":"integer","format":"int32","description":"Código HTTP numérico.","example":404},"error":{"type":"string","description":"Frase HTTP.","example":"Not Found"},"codigo":{"type":"string","description":"Código estable del error.","enum":["AUTZ-003","AUTZ-004","CAS-001","CAS-404","CAS-409","CAS-422","CAS-500"],"example":"CAS-404"},"mensaje":{"type":"string","description":"Mensaje legible para el consumidor.","example":"No existe un caso accesible para el usuario autenticado."},"detalles":{"type":"object","additionalProperties":{"type":"string"},"description":"Detalle por campo, solo para errores de validación.","example":{"accion":"La acción es obligatoria."}},"ruta":{"type":"string","description":"Ruta solicitada.","example":"/casos/7d6b3c3c-9d22-4b10-8d3d-1f3900c13f20"},"timestamp":{"type":"string","format":"date-time","description":"Instante UTC del error.","example":"2027-02-01T10:00:00Z"}}},"PaginaDTO":{"type":"object","description":"Página de resultados de la API.","properties":{"contenido":{"type":"array","description":"Contenido de la página.","items":{}},"pagina":{"type":"integer","format":"int32","description":"Número de página, base cero.","example":0},"tamano":{"type":"integer","format":"int32","description":"Tamaño de página solicitado.","example":20},"total":{"type":"integer","format":"int64","description":"Total de elementos encontrados.","example":42}}}},"securitySchemes":{"bearerAuth":{"type":"http","description":"JWT Bearer emitido por smid-auth.","scheme":"bearer","bearerFormat":"JWT"}}}}