ucativa.","maxLength":600,"minLength":0},"orden":{"type":["integer","null"],"format":"int32","description":"Orden entre hermanos.","example":3},"idPadreAltKey":{"type":["string","null"],"description":"altKey del nuevo padre.","example":"11111111-1111-4111-8111-000000000003"}},"required":["nombre"]},"DerechoArbolDTO":{"type":"object","description":"Nodo del arbol anidado de derechos.","properties":{"altKey":{"type":"string","description":"Identificador publico opaco.","example":"11111111-1111-4111-8111-000000000003"},"codigo":{"type":"string","example":"EDU"},"nombre":{"type":"string","example":"Derecho a la educacion"},"nivel":{"type":"integer","format":"int32","description":"Profundidad en el arbol; 0 es raiz.","example":0},"hijos":{"description":"Hijos directos. Ejemplo: EDU.ACCESO bajo EDU."}}},"DerechoDetalleDTO":{"type":"object","description":"Detalle publico de un derecho.","properties":{"altKey":{"type":"string","description":"Identificador publico opaco.","example":"11111111-1111-4111-8111-000000000003"},"codigo":{"type":"string","example":"EDU"},"nombre":{"type":"string","example":"Derecho a la educacion"},"nivel":{"type":"integer","format":"int32","example":0},"descripcion":{"type":["string","null"],"example":"Acceso, permanencia y calidad en la educacion."},"vigente":{"type":"boolean","example":true},"hijos":{"type":"array","description":"Hijos directos vigentes.","items":{"$ref":"#/components/schemas/DerechoArbolDTO"}}}},"ErrorResponse":{"type":"object","description":"Sobre de error unificado del ecosistema SMID.","properties":{"status":{"type":"integer","format":"int32","description":"Estado HTTP numerico.","example":404},"error":{"type":"string","description":"Frase HTTP estandar.","example":"Not Found"},"codigo":{"type":"string","description":"Codigo estable de error.","enum":["AUTZ-003","AUTZ-004","CAT-001","CAT-002","CAT-003","CAT-004","CAT-005","CAT-006","CAT-500"],"example":"CAT-001"},"mensaje":{"type":"string","description":"Mensaje legible.","example":"El derecho solicitado no existe."},"detalles":{"type":["object","null"],"additionalProperties":{"type":"string"},"description":"Detalles campo-mensaje solo en errores de validacion."},"ruta":{"type":"string","description":"Ruta interna que produjo el error.","example":"/catalogo/derechos/abc"},"timestamp":{"type":"string","format":"date-time","description":"Instante UTC del error.","example":"2026-06-13T12:34:56.789Z"}}},"CrearDerechoRequest":{"type":"object","description":"Solicitud de creacion de derecho. idPadreAltKey nulo crea una raiz.","properties":{"idPadreAltKey":{"type":["string","null"],"description":"altKey del padre; nulo crea raiz.","example":"11111111-1111-4111-8111-000000000003"},"codigo":{"type":"string","description":"Codigo estable e inmutable.","example":"EDU.INCLUSION","maxLength":40,"minLength":0},"nombre":{"type":"string","example":"Inclusion educativa","maxLength":200,"minLength":0},"descripcion":{"type":["string","null"],"example":"Medidas de acceso, inclusion y permanencia.","maxLength":600,"minLength":0},"orden":{"type":["integer","null"],"format":"int32","description":"Orden entre hermanos.","example":3}},"required":["codigo","nombre"]},"CrearCausaRequest":{"type":"object","description":"Solicitud de creacion de causa para un derecho.","properties":{"codigo":{"type":"string","description":"Codigo unico dentro del derecho.","example":"BARRERA_ACCESIBILIDAD","maxLength":40,"minLength":0},"nombre":{"type":"string","example":"Barreras de accesibilidad","maxLength":200,"minLength":0}},"required":["codigo","nombre"]},"CausaDTO":{"type":"object","description":"Causa asociada a un derecho.","properties":{"altKey":{"type":"string","description":"Identificador publico opaco.","example":"22222222-2222-4222-8222-000000000001"},"codigo":{"type":"string","description":"Codigo unico dentro del derecho.","example":"DESERCION"},"nombre":{"type":"string","example":"Desercion escolar"},"vigente":{"type":"boolean","example":true}}},"DerechoPlanoDTO":{